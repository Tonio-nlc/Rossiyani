# SQLite database file (development)
DATABASE_URL="file:./dev.db"

# AI provider: "claude" | "openai"
AI_PROVIDER="claude"

# Provider API keys (set the one matching AI_PROVIDER)
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o"

# Admin route protection (to be implemented)
ADMIN_SECRET=""

# Audio TTS — optional; without keys, browser speech synthesis is used as fallback
AUDIO_TTS_PROVIDER="azure"
AZURE_SPEECH_KEY=""
AZURE_SPEECH_REGION="westeurope"
ELEVENLABS_API_KEY=""
ELEVENLABS_MODEL="eleven_multilingual_v2"
ELEVENLABS_VOICE_RU=""

# Auth — session secret for cookie signing (set a long random string in production)
AUTH_SECRET=""

# Email (password reset) — not wired yet; tokens logged in development
# RESEND_API_KEY=""
